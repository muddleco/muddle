generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  apps      App[]
}

enum Service {
  GOOGLE
  MICROSOFT
}

model App {
  id        Int      @id @default(autoincrement())
  type      Service
  key       Json?
  user      User @relation(fields: [userId], references: [id])
  userId    Int
}